# --- AdminPanel специфичные параметры ---
# Общие параметры (DB_*, REDIS_*, токены) — в shared.env
# DB_HOST и REDIS_HOST задаются через environment: в docker-compose.yml

# Внутренний адрес core-api
CORE_API_BASE=http://core-api:5001

# SQLite БД для хранения сессий и тестов AdminPanel
ADMIN_DB_URL=sqlite:////app/admin_db/admin_panel.db

# ОБЯЗАТЕЛЬНО: случайная строка для подписи сессий
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=replace-with-random-secret

# Параметры тестирования (dsapi)
TEST_API_BASE=http://dsapi:5050/api/v1/pipeline_testing
TEST_TOKEN=same-as-API_AUTH_TOKEN-in-dsapi-env

# Параметры БД (дублируются для синхронизации с shared.env)
DB_NAME=eco
DB_USER=postgres
DB_PASSWORD=changeme
