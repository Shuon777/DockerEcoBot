              "pm.test(\"Response contains at least 1 object with subtype 'Заповедники'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.objects.length).to.be.at.least(1);",
              "    var hasZapovedniki = jsonData.objects.some(function(obj) {",
              "        var subtypes = obj.properties.subtypes;",
              "        if (!subtypes) return false;",
              "        subtypes = Array.isArray(subtypes) ? subtypes : [subtypes];",
              "        return subtypes.includes(\"Заповедники\");",
              "    });",
              "    pm.expect(hasZapovedniki).to.be.true;",
              "});",
              "",
              "pm.test(\"All resources have modality_type 'Текст'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.resources.length).to.be.at.least(1);",
              "    jsonData.resources.forEach(function(resource) {",
              "        pm.expect(resource.modality_type).to.equal(\"Текст\");",
              "    });",
              "});",
              "",
              "pm.test(\"Response contains only text resources (no geodata or images)\", function () {",
              "    var jsonData = pm.response.json();",
              "    var hasNonText = jsonData.resources.some(function(resource) {",
              "        return resource.modality_type !== \"Текст\";",
              "    });",
              "    pm.expect(hasNonText).to.be.false;",
              "});",
              "",
              "pm.test(\"Response time is acceptable\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ]
          }
        }
