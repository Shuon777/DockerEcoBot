          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"At least 1 object found\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.objects.length).to.be.at.least(1);",
              "});",
              "",
              "pm.test(\"All objects have location containing 'Листвянка'\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.objects.forEach(function(obj) {",
              "        var location = obj.properties.exact_location || '';",
              "        pm.expect(location.toLowerCase()).to.include('листвянка');",
              "    });",
              "});",
              "",
              "pm.test(\"All objects have subtype 'Достопримечательности'\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.objects.forEach(function(obj) {",
              "        var subtypes = Array.isArray(obj.properties.subtypes) ? obj.properties.subtypes : [obj.properties.subtypes];",
              "        pm.expect(subtypes).to.include('Достопримечательности');",
              "    });",
