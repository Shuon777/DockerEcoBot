    {
      "name": "TC-25: Покажи байкальский музей на карте (поиск по синониму с геоданными)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains objects with subtype 'Музеи'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.objects.length).to.be.at.least(1);",
              "    jsonData.objects.forEach(function(obj) {",
              "        if (obj.properties && obj.properties.subtypes) {",
              "            var subtypes = Array.isArray(obj.properties.subtypes) ? obj.properties.subtypes : [obj.properties.subtypes];",
              "            pm.expect(subtypes).to.include(\"Музеи\");",
              "        }",
              "    });",
              "});",
              "",
              "pm.test(\"Response contains Байкальский музей СО РАН (id=6753)\", function () {",
              "    var jsonData = pm.response.json();",
              "    var ids = jsonData.objects.map(function(obj) { return obj.id; });",
              "    pm.expect(ids).to.include(6753);",
              "});",
              "",
              "pm.test(\"Response contains resources with modality_type 'Геоданные'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.resources.length).to.be.at.least(1);",
              "    var hasGeoData = jsonData.resources.some(function(resource) {",
              "        return resource.modality_type === \"Геоданные\";",
              "    });",
              "    pm.expect(hasGeoData).to.be.true;",
              "});",
              "",
              "pm.test(\"Coordinates are valid Point\", function () {",
              "    var jsonData = pm.response.json();",
              "    var geoResource = jsonData.resources.find(function(r) { return r.modality_type === \"Геоданные\"; });",
              "    pm.expect(geoResource).to.exist;",
              "    pm.expect(geoResource.content.geojson.type).to.equal(\"Point\");",
              "    pm.expect(geoResource.content.geojson.coordinates.length).to.equal(2);",
              "    pm.expect(geoResource.content.geojson.coordinates[0]).to.be.within(100, 110);",
              "    pm.expect(geoResource.content.geojson.coordinates[1]).to.be.within(50, 60);",
              "});",
              "",
              "pm.test(\"Map links are present\", function () {",
              "    var jsonData = pm.response.json();",
              "    var geoResource = jsonData.resources.find(function(r) { return r.modality_type === \"Геоданные\"; });",
              "    pm.expect(geoResource.content.map_links.static).to.be.a.string;",
              "    pm.expect(geoResource.content.map_links.interactive).to.be.a.string;",
              "});",
              "",
              "pm.test(\"Response time is acceptable\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ]
          }
        }
      ],
