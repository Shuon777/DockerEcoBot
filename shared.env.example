# =============================================================
# shared.env — общая конфигурация для всех сервисов EcoBot
# Управляется через AdminPanel → Настройки
# Загружается: backend, core-api, gigachat, admin
#
# ИНСТРУКЦИЯ:
#   Скопируйте этот файл: cp shared.env.example shared.env
#   Заполните реальными значениями
#   НИКОГДА не коммитьте shared.env в git
# =============================================================

# --- Публичные адреса ---
# В продакшене: https://yourdomain.com  |  Локально: http://localhost
PUBLIC_BASE_URL=http://localhost
BASE_URL_MAPS=http://localhost/maps/

# --- Внутренние адреса сервисов (Docker-сеть) ---
ECOBOT_API_BASE_URL=http://backend:5555

# --- PostgreSQL (хост задаётся через environment: в docker-compose) ---
DB_PORT=5432
DB_NAME=eco
DB_USER=postgres
DB_PASSWORD=changeme

# --- Redis (хост задаётся через environment: в docker-compose) ---
REDIS_PORT=6379
REDIS_DB=1

# --- LLM (Ollama / OpenAI-compatible) ---
LLM_PROVIDER=qwen
# Если Ollama на хост-машине (Docker Desktop): host.docker.internal
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:14b

# --- GigaChat (Sber) ---
GIGACHAT_CREDENTIALS=your_gigachat_base64_credentials
GIGACHAT_MODEL=GigaChat-2-Max
SBER_KEY_ENTERPRICE=your_sber_key_here

# --- Telegram-боты ---
BOT_TOKEN=your_telegram_bot_token
MAX_BOT_TOKEN=your_max_bot_token

# --- STAND API (внешний сервис достопримечательностей) ---
STAND_ENDPOINT=http://84.237.20.90:8084/scripts/sights_ii.jsp
STAND_SECRET_KEY=your_stand_secret_key
