# ============================================================
# DockerEcoBot — .env.example
# Скопируйте в .env нужного сервиса и заполните реальными значениями
# ============================================================

# --- PostgreSQL (db_custom/.env, также используется backend и admin) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=eco
# DB_HOST устанавливается через environment: в docker-compose (значение: db)
DB_PORT=5432
DB_NAME=eco
DB_USER=postgres
DB_PASSWORD=changeme

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1

# --- Публичный домен (для ссылок в сообщениях пользователям) ---
# В продакшене: https://yourdomain.com
# Локально: http://localhost
PUBLIC_BASE_URL=https://yourdomain.com

# --- Внутренний адрес backend (для сервис-to-сервис вызовов) ---
ECOBOT_API_BASE_URL=http://backend:5555

# --- Адрес GigaChat микросервиса ---
GIGACHAT_FALLBACK_URL=http://gigachat:5556/ask_simple

# --- Rasa ---
RASA_WEBHOOK_URL=http://rasa:5005/webhooks/rest/webhook

# --- LLM / Ollama (внешний, не контейнеризован) ---
# Если Ollama на хост-машине (Docker Desktop): host.docker.internal
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:14b
LLM_PROVIDER=qwen

# --- GigaChat API (Sber) ---
SBER_KEY_ENTERPRICE=your_sber_key_here
GIGACHAT_CREDENTIALS=your_gigachat_base64_credentials
GIGACHAT_MODEL=GigaChat-2-Max

# --- Telegram Bot ---
BOT_TOKEN=your_telegram_bot_token
STAND_SECRET_KEY=your_stand_secret_key
STAND_ENDPOINT=http://84.237.20.90:8084/scripts/sights_ii.jsp

# --- Пути (внутри контейнера, менять только при изменении volumes) ---
USER_SETTINGS_PATH=/app/data/user_settings.json
USER_LOCK_SETTINGS_PATH=/app/data/user_settings.json.lock
MAPS_DIR=/app/maps
FAISS_INDEX_PATH=./faiss_index_path
EMBEDDING_MODELS_BASE_DIR=/app/embedding_models
EMBEDDING_MODEL=BERTA

# --- salut_bot прочее ---
YANDEX_API_KEY=your_yandex_api_key
GITHUB_TOKEN=your_github_token
GITHUB_USER=your_github_user
ADMIN_PASSWORD=changeme

# --- AdminPanel ---
ADMIN_DB_URL=sqlite:////app/admin_db/admin_panel.db
BOT_CORE_URL=http://telegram:8080/test_query
SESSION_SECRET_KEY=generate-a-random-32-char-string

# --- Testing (только для разработки, запуск: docker-compose --profile dev up testing) ---
API_AUTH_TOKEN=generate-a-random-token
REMOTE_OLLAMA_URL=http://host.docker.internal:11434
TEST_API_BASE=http://testing:5050/api/v1/pipeline_testing
TEST_TOKEN=same-as-API_AUTH_TOKEN
